+#elif defined(__SWITCH__)
+// libnx exports common names like Result, Service, and u128 in the global namespace.
+// Hide them while including libnx JIT declarations so oaknut does not leak those names downstream.
+#    define Result libnx_Result
+#    define Service libnx_Service
