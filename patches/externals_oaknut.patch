+#    define s128 libnx_s128
+#    define vu128 libnx_vu128
+#    define vs128 libnx_vs128
+extern "C" {
+#    include <switch/kernel/jit.h>
+}
+#    undef BIT
+#    undef BITL
+#    undef Result
+#    undef Service
+#    undef u128
+#    undef s128
+#    undef vu128
+#    undef vs128
 #else
 #    include <sys/mman.h>
 #endif
@@ -40,12 +60,31 @@ public:
         m_memory = (std::uint32_t*)mmap(nullptr, size, PROT_MPROTECT(PROT_READ | PROT_WRITE | PROT_EXEC), MAP_ANON | MAP_PRIVATE, -1, 0);
 #elif defined(__OpenBSD__)
         m_memory = (std::uint32_t*)mmap(nullptr, size, PROT_READ | PROT_EXEC, MAP_ANON | MAP_PRIVATE, -1, 0);
+#elif defined(__SWITCH__)
+        m_size = (size + 0xfff) & ~std::size_t{0xfff};
+        const auto rc = jitCreate(&m_jit, m_size);
+        if (rc != 0)
+            throw std::bad_alloc{};
+        if (jitTransitionToWritable(&m_jit) != 0) {
+            jitClose(&m_jit);
+            throw std::bad_alloc{};
+        }
+        m_memory = (std::uint32_t*)jitGetRwAddr(&m_jit);
+        m_executable_memory = (std::uint32_t*)jitGetRxAddr(&m_jit);
+        if (m_memory == nullptr || m_executable_memory == nullptr) {
+            jitClose(&m_jit);
+            throw std::bad_alloc{};
+        }
 #else
         m_memory = (std::uint32_t*)mmap(nullptr, size, PROT_READ | PROT_WRITE | PROT_EXEC, MAP_ANON | MAP_PRIVATE, -1, 0);
 #endif
 
         if (m_memory == nullptr)
             throw std::bad_alloc{};
+#if !defined(_WIN32) && !defined(__SWITCH__)
+        if (m_memory == (std::uint32_t*)MAP_FAILED)
+            throw std::bad_alloc{};
+#endif
     }
 
     ~CodeBlock()
@@ -55,6 +94,8 @@ public:
 
 #if defined(_WIN32)
         VirtualFree((void*)m_memory, 0, MEM_RELEASE);
+#elif defined(__SWITCH__)
+        jitClose(&m_jit);
