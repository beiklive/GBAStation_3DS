diff --git a/src/dynarmic/common/spin_lock_arm64.cpp b/src/dynarmic/common/spin_lock_arm64.cpp
index ccf807e2..223e8661 100644
--- a/src/dynarmic/common/spin_lock_arm64.cpp
+++ b/src/dynarmic/common/spin_lock_arm64.cpp
@@ -35,6 +35,32 @@ void EmitSpinLockUnlock(oaknut::CodeGenerator& code, oaknut::XReg ptr) {
     code.STLR(WZR, ptr);
 }
 
+#ifdef __SWITCH__
+
+// Do not use a runtime-generated (JIT) spinlock on the Switch. The JIT'd version
+// lives in a global oaknut::CodeBlock whose svcControlCodeMemory mappings are still
+// present when the process hands control back to nx-hbloader; the leaked locked heap
+// page makes hbl's reload of hbmenu fail with 0xD401 (InvalidCurrentMemory) and abort.
+// Plain acquire/release atomics compile to the same LDAXR/STXR/STLR sequences that
+// EmitSpinLockLock/EmitSpinLockUnlock generate, with no code memory to leak.
+
+void SpinLock::Lock() {
+    for (;;) {
+        int expected = 0;
+        if (__atomic_compare_exchange_n(&storage, &expected, 1, false, __ATOMIC_ACQUIRE,
+                                        __ATOMIC_RELAXED)) {
+            return;
+        }
+        __asm__ volatile("yield" ::: "memory");
+    }
+}
+
+void SpinLock::Unlock() {
+    __atomic_store_n(&storage, 0, __ATOMIC_RELEASE);
+}
+
+#else
+
 namespace {
 
 struct SpinLockImpl {
@@ -54,7 +80,7 @@ SpinLockImpl impl;
 
 SpinLockImpl::SpinLockImpl()
         : mem{4096}
-        , code{mem.ptr(), mem.ptr()} {}
+        , code{mem.wptr(), mem.xptr()} {}
 
 void SpinLockImpl::Initialize() {
     mem.unprotect();
@@ -83,4 +109,6 @@ void SpinLock::Unlock() {
     impl.unlock(&storage);
 }
 
+#endif  // __SWITCH__
+
 }  // namespace Dynarmic
